<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - Casino Royale</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="d-flex justify-between align-center mb-4">
            <div>
                <h1 class="text-gold">Casino Royale</h1>
                <p>Welcome back, <%= user.username %>! </p>
            </div>
            <a href="/" class="btn btn-secondary">Logout</a>
        </div>

        <!-- Balance & Vitals -->
        <div class="card mb-4 text-center">
            <h2>Your Balance</h2>
            <h1 class="text-success" style="font-size: 3rem; margin: 0;">$<%= user.balance %></h1>
            <p style="margin: 0; opacity: 0.7;">Role: <%= user.role %></p>
        </div>

        <!-- Casino Floor -->
        <div class="card mb-4">
            <h2 class="text-center mb-3">Casino Floor</h2>
            <div class="grid-3">
                <a href="/slots" class="game-card" style="text-decoration: none; color: inherit;">
                    <h4>🎰 Slots</h4>
                    <p class="btn btn-primary">Play Slots</p>
                </a>
                <a href="/blackjack" class="game-card" style="text-decoration: none; color: inherit;">
                    <h4>🃏 Blackjack</h4>
                    <p class="btn btn-primary">Play Blackjack</p>
                </a>
                <a href="/roulette" class="game-card" style="text-decoration: none; color: inherit;">
                    <h4>🎡 Roulette</h4>
                    <p class="btn btn-primary">Play Roulette</p>
                </a>
            </div>
        </div>

        <!-- Actions Grid -->
        <div class="grid-3">
            <!-- Transfer Chips -->
            <div class="card">
                <h3 class="text-center mb-3">Transfer Chips</h3>
                <form action="/api/transfer" method="POST">
                    <label for="targetUserId">Target User ID</label>
                    <input type="number" id="targetUserId" name="targetUserId" class="form-control" placeholder="e.g., 2" required>
                    <label for="amount">Amount</label>
                    <input type="number" id="amount" name="amount" class="form-control" placeholder="e.g., -50000" required>
                    <button type="submit" class="btn btn-secondary" style="width: 100%;">Transfer</button>
                </form>
            </div>

            <!-- Redeem Promo -->
            <div class="card">
                <h3 class="text-center mb-3">Redeem Promo</h3>
                <form action="/api/promo" method="POST">
                    <label for="promoCode">Promo Code</label>
                    <input type="text" id="promoCode" name="promoCode" class="form-control" placeholder="WELCOME100" required>
                    <!-- Hidden field for Mass Assignment exploit -->
                    <!-- <input type="hidden" name="role" value="admin"> -->
                    <button type="submit" class="btn btn-secondary" style="width: 100%;">Redeem</button>
                </form>
            </div>

            <!-- AI Support -->
            <div class="card text-center d-flex" style="align-items: center; justify-content: center;">
                 <a href="/chat" class="btn btn-secondary">💬 AI Support Chat</a>
            </div>
        </div>

    </div>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - Casino Royale</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="app-layout">

    <header class="header">
        <h1>Casino Royale</h1>
        <div>
            <span>Welcome, <%= user.username %>!</span>
            <a href="/" class="btn btn-secondary" style="margin-left: 1rem;">Logout</a>
        </div>
    </header>

    <aside class="sidebar">
        <h2>Navigation</h2>
        <nav>
            <ul>
                <li><a href="/dashboard" class="active">🏠 Dashboard</a></li>
                <li><a href="/slots">🎰 Slots</a></li>
                <li><a href="/roulette">🎡 Roulette</a></li>
                <li><a href="/blackjack">🃏 Blackjack</a></li>
                <li><a href="/chat">💬 AI Support</a></li>
            </ul>
        </nav>
    </aside>

    <main class="main-content">
        <!-- Balance & Vitals -->
        <div class="card mb-4 text-center">
            <h2>Your Balance</h2>
            <h1 class="text-success" style="font-size: 3rem; margin: 0;">$<%= user.balance %></h1>
            <p style="margin: 0; opacity: 0.7;">Role: <%= user.role %></p>
            
            <% if (user.role === 'admin') { %>
                <div class="admin-actions" style="margin-top: 15px;">
                    <form action="/api/add-funds" method="POST" class="d-flex justify-center align-center" style="gap: 10px;">
                        <input type="number" name="amount" class="form-control" placeholder="e.g., 10000" required style="width: auto; margin-bottom: 0;">
                        <button type="submit" class="btn btn-primary">Add Funds</button>
                    </form>
                </div>
            <% } %>
        </div>

        <!-- Actions Grid -->
        <div class="grid-3">
            <!-- Transfer Chips -->
            <div class="card">
                <h3 class="text-center mb-3">Transfer Chips</h3>
                <form action="/api/transfer" method="POST">
                    <label for="targetUserId">Target User ID</label>
                    <input type="number" id="targetUserId" name="targetUserId" class="form-control" placeholder="e.g., 2" required>
                    <label for="amount">Amount</label>
                    <input type="number" id="amount" name="amount" class="form-control" placeholder="e.g., 500" required>
                    <button type="submit" class="btn btn-secondary" style="width: 100%;">Transfer</button>
                </form>
            </div>

            <!-- Redeem Promo -->
            <div class="card">
                <h3 class="text-center mb-3">Redeem Promo</h3>
                <form action="/api/promo" method="POST">
                    <label for="promoCode">Promo Code</label>
                    <input type="text" id="promoCode" name="promoCode" class="form-control" placeholder="WELCOME100" required>
                    <button type="submit" class="btn btn-secondary" style="width: 100%;">Redeem</button>
                </form>
            </div>

            <!-- Empty Card for alignment -->
            <div class="card" style="background: transparent; border-color: transparent;"></div>
        </div>
    </main>

    <footer class="footer">
        <p>&copy; 2024 Casino Royale. All rights reserved. Please play responsibly.</p>
    </footer>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Roulette - Casino Royale</title>
    <link rel="stylesheet" href="/css/style.css">
    <!-- Styles for the Roulette Wheel & Results -->
    <style>
        .roulette-container {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            padding: 2rem;
            background-color: #2d3748;
            border-radius: 10px;
            margin-bottom: 2rem;
            overflow: hidden; /* To contain the result overlay */
        }
        .wheel {
            position: relative;
            width: 300px;
            height: 300px;
            border: 10px solid #4a5568;
            border-radius: 50%;
            overflow: hidden;
            /* The transition will be controlled by JS now */
            transition: transform 5s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .wheel::before { /* Center of the wheel */
            content: '';
            position: absolute;
            width: 40px;
            height: 40px;
            background: #a0aec0;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 2;
            border: 3px solid #718096;
        }
        .pointer {
            position: absolute;
            top: -5px; /* Adjusted position */
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 15px solid transparent;
            border-right: 15px solid transparent;
            border-top: 20px solid #fed7d7;
            z-index: 5;
        }
        .result-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 10;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.5s ease-in-out;
        }
        .result-overlay.show {
            opacity: 1;
            pointer-events: auto;
        }
        .result-number {
            font-size: 10rem;
            font-weight: bold;
            line-height: 1;
        }
        .result-text {
            font-size: 2rem;
            margin-top: 1rem;
        }
        .result-overlay.win .result-number,
        .result-overlay.win .result-text {
            color: #48bb78; /* Green */
            text-shadow: 0 0 15px #48bb78;
        }
        .result-overlay.lose .result-number,
        .result-overlay.lose .result-text {
            color: #e53e3e; /* Red */
            text-shadow: 0 0 15px #e53e3e;
        }
        /* [NUEVO] Estilo para forzar el grid */
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }
    </style>
</head>
<body class="app-layout">

    <header class="header">
        <h1>Casino Royale</h1>
        <div>
            <span>Balance: <span class="text-success" id="user-balance">$<%= user.balance %></span></span>
            <a href="/" class="btn btn-secondary" style="margin-left: 1rem;">Logout</a>
        </div>
    </header>

    <aside class="sidebar">
        <h2>Navigation</h2>
        <nav>
            <ul>
                <li><a href="/dashboard">🏠 Dashboard</a></li>
                <li><a href="/slots">🎰 Slots</a></li>
                <li><a href="/roulette" class="active">🎡 Roulette</a></li>
                <li><a href="/blackjack">🃏 Blackjack</a></li>
                <li><a href="/chat">💬 AI Support</a></li>
            </ul>
        </nav>
    </aside>

    <main class="main-content">
        <div class="text-center mb-4">
            <h1 class="text-gold">🎡 Roulette 🎡</h1>
            <p>Place your bets, the wheel is spinning!</p>
        </div>
        
        <div class="roulette-container">
            <div class="pointer"></div>
            <div class="wheel" id="roulette-wheel">
                <!-- The wheel background is now generated by JS -->
            </div>
            <!-- [NUEVO] Contenedor de resultado superpuesto -->
            <div class="result-overlay" id="result-overlay">
                <div class="result-number"></div>
                <div class="result-text"></div>
            </div>
        </div>

        <!-- Payouts and Calculator Side-by-Side -->
        <div class="grid-2 mb-4">
            <div class="card bg-dark text-white border-secondary">
                <div class="card-header"><h5 class="mb-0">Payouts Table</h5></div>
                <div class="card-body p-0">
                    <table class="table table-dark table-striped mb-0">
                        <thead><tr><th>Bet Type</th><th>Payout</th></tr></thead>
                        <tbody>
                            <tr><td>Straight Up (1 number)</td><td>35 to 1</td></tr>
                            <tr><td>Red or Black</td><td>2 to 1</td></tr>
                            <tr><td>Even or Odd</td><td>2 to 1</td></tr>
                            <tr><td>Column (12 numbers)</td><td>3 to 1</td></tr>
                            <tr><td>Dozen (12 numbers)</td><td>3 to 1</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card bg-dark text-white border-secondary">
                <div class="card-header"><h5 class="mb-0">🧮 Multiple Bet Calculator</h5></div>
                <div class="card-body">
                    <p class="card-text text-white-50" style="font-size: 0.9rem;">Estimate winnings from complex bets.<br><strong>Example:</strong> <code>(10 * 35) + (50 * 2)</code></p>
                    <form action="/api/roulette-calc" method="POST">
                        <div class="mb-3">
                            <label for="betFormula" class="form-label">Bet Formula:</label>
                            <input type="text" class="form-control bg-secondary text-white border-dark" id="betFormula" name="betFormula" placeholder="(50 * 2) + (10 * 35)" required>
                        </div>
                        <button type="submit" class="btn btn-success">Calculate Winnings</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Place a Bet Form -->
        <div class="card bg-dark text-white border-secondary mb-4">
            <div class="card-header">
                <h5 class="mb-0">Place a Bet</h5>
            </div>
            <div class="card-body">
                <form id="bet-form">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <label for="betAmount" class="form-label">Bet Amount:</label>
                            <input type="number" class="form-control bg-secondary text-white" id="betAmount" name="betAmount" value="10" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bet Type:</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="betType" id="betEven" value="even" checked>
                                <label class="form-check-label" for="betEven">Even</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="betType" id="betOdd" value="odd">
                                <label class="form-check-label" for="betOdd">Odd</label>
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" id="spin-and-bet-button" class="btn btn-success w-100">Place Bet & Spin</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </main>

    <footer class="footer">
        <p>&copy; 2026 Casino Royale. All rights reserved. Please play responsibly.</p>
    </footer>

    <!-- [MODIFICADO] Script de la ruleta reescrito completamente -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const wheel = document.getElementById('roulette-wheel');
            const betForm = document.getElementById('bet-form');
            const spinButton = document.getElementById('spin-and-bet-button');
            const userBalanceElement = document.getElementById('user-balance');
            const resultOverlay = document.getElementById('result-overlay');
            const resultNumberElement = resultOverlay.querySelector('.result-number');
            const resultTextElement = resultOverlay.querySelector('.result-text');

            const numbers = [0, 32, 15, 19, 4, 21, 2, 25, 17, 34, 6, 27, 13, 36, 11, 30, 8, 23, 10, 5, 24, 16, 33, 1, 20, 14, 31, 9, 22, 18, 29, 7, 28, 12, 35, 3, 26];
            const colors = { red: [32, 19, 21, 25, 34, 27, 36, 30, 23, 5, 16, 1, 14, 9, 18, 7, 12, 3], black: [15, 4, 2, 17, 6, 13, 11, 8, 10, 24, 33, 20, 31, 22, 29, 28, 35, 26], green: [0] };
            const sliceAngle = 360 / numbers.length;
            let isSpinning = false;
            let currentRotation = 0;

            // Generate wheel using conic-gradient for a smooth, clean look
            const colorStops = [];
            const slicePercentage = 100 / numbers.length;
            numbers.forEach((num, i) => {
                let color = 'black';
                if (colors.red.includes(num)) color = '#c53030';
                if (colors.green.includes(num)) color = '#38a169';
                // Define start and end percentages for this slice
                const start = i * slicePercentage;
                const end = (i + 1) * slicePercentage;
                colorStops.push(`${color} ${start}% ${end}%`);
            });
            // Set the background, starting the gradient from the top (-90deg) to align with the pointer
            wheel.style.background = `conic-gradient(from -90deg, ${colorStops.join(', ')})`;

            betForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                if (isSpinning) return;

                isSpinning = true;
                spinButton.disabled = true;
                spinButton.textContent = 'Spinning...';
                resultOverlay.classList.remove('show', 'win', 'lose');

                const betType = new FormData(betForm).get('betType');

                try {
                    const response = await fetch('/api/roulette/bet', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ betType })
                    });

                    const data = await response.json();

                    if (!response.ok) {
                        throw new Error(data.error || 'An error occurred.');
                    }
                    
                    // Start the spin
                    const winningNumberIndex = numbers.indexOf(data.winningNumber);
                    const extraRotations = 5; // More rotations for suspense
                    const targetAngle = (360 * extraRotations) - (winningNumberIndex * sliceAngle);
                    
                    // Add a slight random offset for realism
                    const slightOffset = (Math.random() - 0.5) * (sliceAngle * 0.8);
                    const finalRotation = targetAngle + slightOffset;

                    currentRotation += finalRotation;
                    wheel.style.transform = `rotate(${currentRotation}deg)`;

                    // Wait for animation to finish
                    setTimeout(() => {
                        resultNumberElement.textContent = data.winningNumber;
                        if(data.win) {
                            resultTextElement.textContent = 'YOU WIN!';
                            resultOverlay.classList.add('win');
                        } else {
                            resultTextElement.textContent = 'YOU LOSE';
                            resultOverlay.classList.add('lose');
                        }
                        resultOverlay.classList.add('show');
                        
                        userBalanceElement.textContent = '$' + data.newBalance;

                        // Allow user to see result before next spin
                        setTimeout(() => {
                           resultOverlay.classList.remove('show');
                           isSpinning = false;
                           spinButton.disabled = false;
                           spinButton.textContent = 'Place Bet & Spin';
                        }, 3000);

                    }, 5000); // Must match CSS transition time

                } catch (error) {
                    alert('Error: ' + error.message);
                    isSpinning = false;
                    spinButton.disabled = false;
                    spinButton.textContent = 'Place Bet & Spin';
                }
            });
        });
    </script>
</body>
</html>
